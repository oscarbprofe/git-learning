# Firebase Web App config (públicas por diseño: la seguridad la dan los authorized domains
# del proyecto Firebase y el método Email link, no el secreto de estos valores).
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_APP_ID=

# Modo desarrollo: salta Firebase y autentica como dev@duocuc.cl.
# Dejar SIN ASIGNAR / vacío en producción.
PUBLIC_AUTH_DISABLED=true
