---
import DuocLogo from './DuocLogo.astro';
import HeaderProgress from '../islands/HeaderProgress.tsx';
import UserMenu from '../islands/UserMenu.tsx';
import SaveStatus from '../islands/SaveStatus.tsx';
---

<header class="site-header">
  <!-- Barra full-bleed: logo a la izquierda, usuario + pestaña a la derecha -->
  <div class="header-bar">
    <a href="/" class="brand" aria-label="Inicio — Git Challenge Duoc UC">
      <DuocLogo size="sm" />
    </a>

    <div class="header-right">
      <SaveStatus client:load />
      <UserMenu client:load />
      <!-- Pestaña amarilla con corte diagonal, eco del bloque "ADMISIÓN" de duoc.cl -->
      <a href="/" class="brand-tab" aria-label="Inicio — Git Challenge">
        <span class="brand-title">Git Challenge</span>
      </a>
    </div>
  </div>

  <!-- Capa alineada al MISMO container que el contenido: la barra de progreso
       calza con el borde izquierdo del contenido de la página. -->
  <div class="header-shell">
    <HeaderProgress client:load />
  </div>
</header>

<style>
  .site-header {
    background: var(--duoc-negro);
    color: var(--duoc-blanco);
    border-bottom: 1px solid #000;
    padding: var(--sp-4) 0;
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.18);
  }

  .header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    text-decoration: none;
    color: var(--duoc-blanco);
    padding-left: var(--sp-5);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    min-width: 0;
  }

  /* Capa centrada con la misma anchura y padding que `.container` (72rem),
     superpuesta sobre la barra. Su contenido (la barra de progreso) queda
     alineado al borde izquierdo del contenido de la página. */
  .header-shell {
    position: absolute;
    inset: 0;
    /* sin width:100% — con left:0/right:0, width auto + margin auto centra la capa
       a la anchura del contenido; con width:100% quedaría pegada a la izquierda. */
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--sp-5);
    display: flex;
    align-items: center;
    pointer-events: none;
    z-index: 1;
  }
  .header-shell > * {
    pointer-events: auto;
  }

  /* Pestaña amarilla flush al borde derecho, alto completo y con el borde
     izquierdo cortado en diagonal (terminación en punta del navbar duoc.cl). */
  .brand-tab {
    align-self: stretch;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    text-decoration: none;
    background: var(--duoc-amarillo);
    color: var(--duoc-negro);
    padding: var(--sp-4) var(--sp-5) var(--sp-4) calc(var(--sp-5) + 26px);
    margin: calc(-1 * var(--sp-4)) 0;
    margin-left: var(--sp-3);
    clip-path: polygon(26px 0, 100% 0, 100% 100%, 0 100%);
    transition: background 0.15s ease;
  }
  .brand-tab:hover {
    background: var(--duoc-amarillo-oscuro);
  }
  .brand-title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--duoc-negro);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  /* En pantallas chicas la barra de progreso pasa a una segunda fila
     (estática, full-width) para no chocar con el logo ni el usuario. */
  @media (max-width: 768px) {
    .brand { padding-left: var(--sp-4); }
    .header-shell {
      position: static;
      max-width: none;
      margin: 0;
      padding: var(--sp-3) var(--sp-4) 0;
    }
    .brand-tab {
      padding: var(--sp-3) var(--sp-4) var(--sp-3) calc(var(--sp-4) + 20px);
      clip-path: polygon(20px 0, 100% 0, 100% 100%, 0 100%);
    }
    .brand-title { font-size: 0.95rem; }
  }
</style>
