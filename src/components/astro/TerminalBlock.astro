---
/** Bloque de terminal simulada con prompt $. Para usar en MDX. */
interface Props {
  title?: string;
}
const { title = 'terminal' } = Astro.props;
---

<div class="terminal">
  <div class="terminal-bar">
    <span class="dot dot-red" aria-hidden="true"></span>
    <span class="dot dot-yellow" aria-hidden="true"></span>
    <span class="dot dot-green" aria-hidden="true"></span>
    <span class="terminal-title">{title}</span>
  </div>
  <pre class="terminal-body"><slot /></pre>
</div>

<style>
  .terminal {
    background: var(--duoc-negro-80);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin: var(--sp-4) 0;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--duoc-gris-oscuro);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    background: #2a2a2a;
    border-bottom: 1px solid #000;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-red {
    background: #ff5f56;
  }
  .dot-yellow {
    background: #ffbd2e;
  }
  .dot-green {
    background: #27c93f;
  }

  .terminal-title {
    margin-left: var(--sp-3);
    color: var(--duoc-gris-claro);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }

  .terminal-body {
    margin: 0;
    padding: var(--sp-4);
    background: transparent;
    color: #e8e8e8;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    line-height: 1.5;
    white-space: pre;
  }

  :global(.terminal-body .prompt) {
    color: var(--duoc-amarillo);
    font-weight: 700;
  }

  :global(.terminal-body .comment) {
    color: #888;
    font-style: italic;
  }

  :global(.terminal-body .out) {
    color: #a4d99c;
  }
</style>
